# Docker-compose environment variables
POSTGRES_USER=testuser
POSTGRES_PASSWORD=testpassword

# Prisma/Next.js environment variables
POSTGRES_PRISMA_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/darts-test"
POSTGRES_URL_NON_POOLING="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/darts-test"

# Optional CueScore provider selection.
# In development, the app automatically falls back to the local fake provider
# when CueScore credentials are not set.
# CUESCORE_PROVIDER=fake
# CUESCORE_USERNAME=
# CUESCORE_PASSWORD=

# Admin UI credentials for /admin
# ADMIN_UI_USERNAME=
# ADMIN_UI_PASSWORD=
