{
  "name": "darts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx dotenv -e .env.development.local -- next dev",
    "build": "NODE_ENV=production prisma generate && NODE_ENV=production next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "studio": "npx dotenv -e .env.development.local -- npx prisma studio",
    "studio:test": "npx dotenv -e .env.test -- npx prisma studio",
    "test": "npx dotenv -e .env.test -- jest",
    "test:watch": "npx dotenv -e .env.test -- jest --watch",
    "test:integration": "JEST_ENV=integration npx dotenv -e .env.test -- jest --runInBand",
    "test:integration:full": "sh ./run-integration-tests.sh",
    "migrate": "npx dotenv -e .env.development.local -- npx prisma db push",
    "migrate:test": "npx dotenv -e .env.test -- npx prisma db push",
    "delete:tournament": "npx dotenv -e .env.development.local -- ts-node -P tsconfig.script.json scripts/delete-tournament.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/postgres": "^0.10.0",
    "@vercel/speed-insights": "^1.3.1",
    "axios": "^1.15.1",
    "jest-mock-extended": "^4.0.1",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.10",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "vercel": "^32.7.2"
  }
}
