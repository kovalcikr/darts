{
  "name": "darts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "npx dotenv -e .env.development.local -- next dev --webpack",
    "build": "NODE_ENV=production npm run prisma:generate && NODE_ENV=production next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "studio": "npx dotenv -e .env.development.local -- npx prisma studio",
    "studio:test": "npx dotenv -e .env.test -- npx prisma studio",
    "pretest": "npm run prisma:generate",
    "test": "npx dotenv -e .env.test -- jest",
    "test:watch": "npx dotenv -e .env.test -- jest --watch",
    "pretest:integration": "npm run migrate:test",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules JEST_ENV=integration npx dotenv -e .env.test -- jest --runInBand",
    "test:integration:full": "sh ./run-integration-tests.sh",
    "migrate": "npx dotenv -e .env.development.local -- npx prisma db push && npm run prisma:generate",
    "migrate:test": "npx dotenv -e .env.test -- npx prisma db push && npm run prisma:generate",
    "delete:tournament": "tsx scripts/delete-tournament.ts",
    "delete:tournament:dev": "npx dotenv -e .env.development.local -- npm run delete:tournament --"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/postgres": "^0.10.0",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.15.1",
    "jest-mock-extended": "^4.0.1",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@jest/globals": "^30.3.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vercel": "^51.8.0"
  }
}
